# ============================================================
# .env.local — NE JAMAIS COMMIT CE FICHIER
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Trouvé dans : Supabase > Settings > API

# URL de l'API Supabase (publique)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJET_ID.supabase.co

# Clé anonyme (publique, safe côté client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service role (SECRÈTE — serveur uniquement)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Base de données PostgreSQL (Prisma) ───────────────────────
# Trouvé dans : Supabase > Settings > Database > Connection string
# Mode : "Transaction" pour DATABASE_URL (pooler)
# Mode : "Session"     pour DIRECT_URL   (direct)

DATABASE_URL=postgresql://postgres.PROJET_ID:MOT_DE_PASSE@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.PROJET_ID:MOT_DE_PASSE@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── JWT Auth ─────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=remplacer_par_une_chaine_aleatoire_de_64_caracteres_minimum
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=autre_chaine_aleatoire_differente_64_chars
REFRESH_TOKEN_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EduSuivi
