// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  professeur
  surveillant
  eleve
}

enum TypeSanction {
  avertissement
  retenue
  exclusion_temp
  exclusion_def
}

model User {
  id        String   @id @default(cuid())
  nom       String
  prenom    String
  email     String   @unique
  password  String
  role      Role
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  eleve        Eleve?        @relation("UserEleve")
  notesCreees  Note[]        @relation("ProfNotes")
  sanctionsCreees Sanction[] @relation("SurvSanctions")
  retardsCreees   Retard[]   @relation("SurvRetards")
  absencesCreees  Absence[]  @relation("SurvAbsences")
  professeurClasses ClasseMatiere[] @relation("ProfClasse")

  @@map("users")
}

model AnneeScolaire {
  id        String   @id @default(cuid())
  libelle   String   // ex: "2024-2025"
  dateDebut DateTime
  dateFin   DateTime
  actif     Boolean  @default(false)

  classes      Classe[]
  inscriptions Inscription[]

  @@map("annees_scolaires")
}

model Classe {
  id              String   @id @default(cuid())
  nom             String
  niveau          String
  anneeId         String
  annee           AnneeScolaire @relation(fields: [anneeId], references: [id])

  inscriptions    Inscription[]
  classesMatieres ClasseMatiere[]

  @@map("classes")
}

model Matiere {
  id         String  @id @default(cuid())
  nom        String
  coefficient Int     @default(1)
  couleur    String  @default("#2563eb")

  classesMatieres ClasseMatiere[]
  notes           Note[]

  @@map("matieres")
}

model ClasseMatiere {
  id         String @id @default(cuid())
  classeId   String
  matiereId  String
  professeurId String

  classe     Classe  @relation(fields: [classeId], references: [id])
  matiere    Matiere @relation(fields: [matiereId], references: [id])
  professeur User    @relation("ProfClasse", fields: [professeurId], references: [id])

  @@unique([classeId, matiereId])
  @@map("classe_matieres")
}

model Eleve {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation("UserEleve", fields: [userId], references: [id], onDelete: Cascade)
  matricule     String   @unique
  dateNaissance DateTime?
  photo         String?
  adresse       String?
  nationalite   String   @default("Burkinabè")

  parents      Parent[]
  inscriptions Inscription[]
  notes        Note[]
  sanctions    Sanction[]
  retards      Retard[]
  absences     Absence[]

  @@map("eleves")
}

model Parent {
  id       String @id @default(cuid())
  eleveId  String
  eleve    Eleve  @relation(fields: [eleveId], references: [id], onDelete: Cascade)
  nom      String
  prenom   String
  telephone String?
  email    String?
  relation String // "père", "mère", "tuteur"

  @@map("parents")
}

model Inscription {
  id        String   @id @default(cuid())
  eleveId   String
  classeId  String
  anneeId   String
  dateInscription DateTime @default(now())

  eleve     Eleve         @relation(fields: [eleveId], references: [id])
  classe    Classe        @relation(fields: [classeId], references: [id])
  annee     AnneeScolaire @relation(fields: [anneeId], references: [id])

  @@unique([eleveId, anneeId])
  @@map("inscriptions")
}

model Note {
  id           String   @id @default(cuid())
  eleveId      String
  matiereId    String
  professeurId String
  valeur       Float
  typeEval     String   // "Devoir 1", "Devoir 2", "Examen", ...
  trimestre    Int      // 1, 2 ou 3
  commentaire  String?
  createdAt    DateTime @default(now())

  eleve      Eleve   @relation(fields: [eleveId], references: [id])
  matiere    Matiere @relation(fields: [matiereId], references: [id])
  professeur User    @relation("ProfNotes", fields: [professeurId], references: [id])

  @@map("notes")
}

model Sanction {
  id           String       @id @default(cuid())
  eleveId      String
  surveillantId String
  type         TypeSanction
  motif        String
  description  String?
  dateDebut    DateTime
  dateFin      DateTime?
  createdAt    DateTime     @default(now())

  eleve       Eleve @relation(fields: [eleveId], references: [id])
  surveillant User  @relation("SurvSanctions", fields: [surveillantId], references: [id])

  @@map("sanctions")
}

model Retard {
  id            String   @id @default(cuid())
  eleveId       String
  surveillantId String
  date          DateTime
  heureArrivee  String
  motif         String?
  justifie      Boolean  @default(false)
  createdAt     DateTime @default(now())

  eleve       Eleve @relation(fields: [eleveId], references: [id])
  surveillant User  @relation("SurvRetards", fields: [surveillantId], references: [id])

  @@map("retards")
}

model Absence {
  id            String   @id @default(cuid())
  eleveId       String
  surveillantId String
  dateDebut     DateTime
  dateFin       DateTime
  motif         String?
  justifiee     Boolean  @default(false)
  createdAt     DateTime @default(now())

  eleve       Eleve @relation(fields: [eleveId], references: [id])
  surveillant User  @relation("SurvAbsences", fields: [surveillantId], references: [id])

  @@map("absences")
}
